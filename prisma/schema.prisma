generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ExecutionRecord {
  id            String   @id @default(cuid())
  title         String
  scene         String
  inputContent  String
  outputContent String
  status        String   @default("pending")
  owner         String   @default("演示用户")
  score         Int?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Template {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String?
  content     String
  isActive    Boolean  @default(true)
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KnowledgeItem {
  id          String   @id @default(cuid())
  title       String
  category    String
  problemDesc String
  solution    String
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
